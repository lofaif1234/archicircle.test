---
import Layout from '../layouts/Layout.astro';
import pageData from '../data/pages/servicios-de-fabricacion.json';

const {
  hero_title = pageData.hero_title,
  hero_subtitle = pageData.hero_subtitle,
  info_1_title = pageData.info_1_title,
  info_1_desc = pageData.info_1_desc,
  info_2_title = pageData.info_2_title,
  info_2_desc = pageData.info_2_desc,
  experience_title = pageData.experience_title,
  experience_item_1 = pageData.experience_item_1,
  experience_item_2 = pageData.experience_item_2,
  experience_item_3 = pageData.experience_item_3,
  experience_item_4 = pageData.experience_item_4
} = Astro.props;
---

<Layout title="Servicios de Fabricación - Archicercle">
    <main>
        <section class="factory-hero-v2">
            <div class="container">
                <h1 class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].hero_title">{hero_title}</h1>
                <p class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].hero_subtitle">{hero_subtitle}</p>
            </div>
        </section>

        <section class="factory-info-grid">
            <div class="container">
                <div class="info-row">
                    <div class="info-block">
                        <h3 class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].info_1_title">{info_1_title}</h3>
                        <p class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].info_1_desc">{info_1_desc}</p>
                    </div>
                    <div class="info-block">
                        <h3 class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].info_2_title">{info_2_title}</h3>
                        <p class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].info_2_desc">{info_2_desc}</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="factory-experience">
            <div class="container">
                <h2 class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].experience_title">{experience_title}</h2>
                <ul class="experience-list">
                    <li class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].experience_item_1">{experience_item_1}</li>
                    <li class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].experience_item_2">{experience_item_2}</li>
                    <li class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].experience_item_3">{experience_item_3}</li>
                    <li class="editable" data-editable="text" data-prop="@data[page_servicios_fabricacion].experience_item_4">{experience_item_4}</li>
                </ul>
            </div>
        </section>
    </main>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import pageData from '../data/pages/coworking.json';

const {
  hero_title = pageData.hero_title,
  hero_subtitle = pageData.hero_subtitle,
  info_1_title = pageData.info_1_title,
  info_2_title = pageData.info_2_title,
  info_3_title = pageData.info_3_title,
  who_title = pageData.who_title,
  who_desc = pageData.who_desc,
  pricing_title = pageData.pricing_title,
  pricing_subtitle = pageData.pricing_subtitle
} = Astro.props;
---

<Layout title="Coworking - Archicercle">
    <main>
        <section class="coworking-hero-full">
            <div class="hero-overlay"></div>
            <div class="container">
                <div class="coworking-hero-content">
                    <h1 class="editable coworking-title" data-editable="text" data-prop="@data[page_coworking].hero_title">{hero_title}</h1>
                    <p class="editable coworking-subtitle" data-editable="text" data-prop="@data[page_coworking].hero_subtitle" set:html={hero_subtitle}></p>
                    <div class="coworking-ctas">
                        <a href="#" class="btn-coworking">Reserva tu puesto</a>
                        <a href="#" class="btn-coworking">Descubre el Fablab</a>
                    </div>
                </div>

                <div class="coworking-divider"></div>

                <div class="info-grid">
                    <div class="info-col">
                        <div class="info-header">
                            <i data-lucide="box" class="check-icon"></i>
                            <h3 class="editable" data-editable="text" data-prop="@data[page_coworking].info_1_title">{info_1_title}</h3>
                        </div>
                        <ul class="info-list">
                            <li>Un taller completo, abierto para ti.</li>
                            <li>Ponemos a tu disposición todas las máquinas que hemos usado durante años en nuestro propio estudio.</li>
                        </ul>
                    </div>

                    <div class="info-col">
                        <div class="info-header">
                            <i data-lucide="zap" class="check-icon"></i>
                            <h3 class="editable" data-editable="text" data-prop="@data[page_coworking].info_2_title">{info_2_title}</h3>
                        </div>
                        <ul class="info-list">
                            <li>Toda la experiencia Archicercle, ahora abierta al público.</li>
                            <li>Maquinaria variada: CNC, láser, impresión 3D, carpintería, metales.</li>
                        </ul>
                    </div>

                    <div class="info-col">
                        <div class="info-header">
                            <i data-lucide="cpu" class="check-icon"></i>
                            <h3 class="editable" data-editable="text" data-prop="@data[page_coworking].info_3_title">{info_3_title}</h3>
                        </div>
                        <ul class="info-list">
                            <li>Reserva tu acceso: elige un plan, por días, mensual, semanal o anual.</li>
                            <li>Llega y fabrica: trae tus diseños o crea aquí mismo.</li>
                        </ul>
                        <a href="#" class="btn-reserva-small">Reserva tu puesto</a>
                    </div>
                </div>
            </div>
        </section>

        <section class="coworking-who-section">
            <div class="container">
                <h2 class="editable" data-editable="text" data-prop="@data[page_coworking].who_title">{who_title}</h2>
                <p class="editable" data-editable="text" data-prop="@data[page_coworking].who_desc">{who_desc}</p>
            </div>
        </section>

        <section class="pricing-section">
            <div class="container">
                <h2 class="editable" data-editable="text" data-prop="@data[page_coworking].pricing_title">{pricing_title}</h2>
                <p class="editable" data-editable="text" data-prop="@data[page_coworking].pricing_subtitle">{pricing_subtitle}</p>
                <div class="pricing-grid">
                    <div class="pricing-card">
                        <h3>Plan Diario</h3>
                        <p class="price">25€<span>/día</span></p>
                        <a href="#" class="btn-pricing">Contratar</a>
                    </div>
                    <div class="pricing-card">
                        <h3>Plan Mensual</h3>
                        <p class="price">200€<span>/mes</span></p>
                        <a href="#" class="btn-pricing">Contratar</a>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

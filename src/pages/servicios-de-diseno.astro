---
import Layout from '../layouts/Layout.astro';
import pageData from '../data/pages/servicios-de-diseno.json';

const {
  hero_title = pageData.hero_title,
  hero_subtitle = pageData.hero_subtitle,
  intro_text = pageData.intro_text,
  design_1_title = pageData.design_1_title,
  design_1_desc = pageData.design_1_desc,
  design_2_title = pageData.design_2_title,
  design_2_desc = pageData.design_2_desc,
  design_3_title = pageData.design_3_title,
  design_3_desc = pageData.design_3_desc
} = Astro.props;
---

<Layout title="Servicios de Diseño - Archicercle">
    <main>
        <section class="design-hero">
            <div class="container">
                <h1 class="editable" data-editable="text" data-prop="@data[page_servicios_diseno].hero_title">{hero_title}</h1>
                <p class="editable" data-editable="text" data-prop="@data[page_servicios_diseno].hero_subtitle">{hero_subtitle}</p>
                <p class="editable" data-editable="text" data-prop="@data[page_servicios_diseno].intro_text">{intro_text}</p>
            </div>
        </section>

        <section class="design-services-grid">
            <div class="container">
                <div class="service-row">
                    <div class="service-item">
                        <h3 class="editable" data-editable="text" data-prop="@data[page_servicios_diseno].design_1_title">{design_1_title}</h3>
                        <p class="editable" data-editable="text" data-prop="@data[page_servicios_diseno].design_1_desc">{design_1_desc}</p>
                    </div>
                    <div class="service-item">
                        <h3 class="editable" data-editable="text" data-prop="@data[page_servicios_diseno].design_2_title">{design_2_title}</h3>
                        <p class="editable" data-editable="text" data-prop="@data[page_servicios_diseno].design_2_desc">{design_2_desc}</p>
                    </div>
                    <div class="service-item">
                        <h3 class="editable" data-editable="text" data-prop="@data[page_servicios_diseno].design_3_title">{design_3_title}</h3>
                        <p class="editable" data-editable="text" data-prop="@data[page_servicios_diseno].design_3_desc">{design_3_desc}</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

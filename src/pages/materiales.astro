---
import Layout from '../layouts/Layout.astro';

const {
  hero_title = "Materiales",
  hero_subtitle = "La base de cada gran proyecto.",
  mat_1_title = "Maderas y Derivados",
  mat_1_desc = "Desde contrachapados hasta maderas nobles.",
  mat_2_title = "Acrílicos y Plásticos",
  mat_2_desc = "Gran variedad de colores y acabados.",
  mat_3_title = "Metales",
  mat_3_desc = "Aluminio, acero y más para proyectos industriales."
} = Astro.props;
---

<Layout title="Materiales - Archicercle">
    <main>
        <section class="material-hero">
            <div class="container">
                <h1 class="editable" data-editable="text" data-prop="hero_title">{hero_title}</h1>
                <p class="editable" data-editable="text" data-prop="hero_subtitle">{hero_subtitle}</p>
            </div>
        </section>

        <section class="material-grid">
            <div class="container">
                <div class="material-item">
                    <h3 class="editable" data-editable="text" data-prop="mat_1_title">{mat_1_title}</h3>
                    <p class="editable" data-editable="text" data-prop="mat_1_desc">{mat_1_desc}</p>
                </div>
                <div class="material-item">
                    <h3 class="editable" data-editable="text" data-prop="mat_2_title">{mat_2_title}</h3>
                    <p class="editable" data-editable="text" data-prop="mat_2_desc">{mat_2_desc}</p>
                </div>
                <div class="material-item">
                    <h3 class="editable" data-editable="text" data-prop="mat_3_title">{mat_3_title}</h3>
                    <p class="editable" data-editable="text" data-prop="mat_3_desc">{mat_3_desc}</p>
                </div>
            </div>
        </section>
    </main>
</Layout>

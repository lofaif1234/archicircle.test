---
import Layout from '../layouts/Layout.astro';
import pageData from '../data/pages/corte-laser-online.json';

const {
  hero_title = pageData.hero_title,
  hero_subtitle = pageData.hero_subtitle,
  hero_description = pageData.hero_description,
  hero_highlight = pageData.hero_highlight,
  hero_img = pageData.hero_img,
  col_1_title = pageData.col_1_title,
  col_1_desc = pageData.col_1_desc,
  col_2_title = pageData.col_2_title,
  col_2_desc = pageData.col_2_desc,
  experience_title = pageData.experience_title,
  experience_desc = pageData.experience_desc,
  experience_img = pageData.experience_img,
  footer_highlight_title = pageData.footer_highlight_title,
  footer_highlight_desc = pageData.footer_highlight_desc
} = Astro.props;
---

<Layout title="Corte Láser Online - Archicercle">
    <main>
        <section class="laser-hero">
            <div class="laser-hero-overlay"></div>
            <img class="editable laser-hero-bg" data-editable="image" data-prop="@data[corte_laser].hero_img" src={hero_img.src} alt={hero_img.alt}>
            
            <div class="container laser-content-wrapper">
                <div class="laser-hero-header">
                    <h1 class="editable laser-title" data-editable="text" data-prop="@data[corte_laser].hero_title" set:html={hero_title}></h1>
                    <div class="laser-intro-text">
                        <p class="editable" data-editable="text" data-prop="@data[corte_laser].hero_subtitle">{hero_subtitle}</p>
                        <p class="editable" data-editable="text" data-prop="@data[corte_laser].hero_description" set:html={hero_description}></p>
                        <p class="editable highlight-p" data-editable="text" data-prop="@data[corte_laser].hero_highlight">{hero_highlight}</p>
                    </div>
                    <a href="#" class="btn-justlaser">Ir a Justlasercut</a>
                </div>

                <div class="laser-columns">
                    <div class="laser-col">
                        <h3 class="editable col-title" data-editable="text" data-prop="@data[corte_laser].col_1_title">{col_1_title}</h3>
                        <p class="editable" data-editable="text" data-prop="@data[corte_laser].col_1_desc">{col_1_desc}</p>
                        <a href="#" class="col-link">Pedir presupuesto automático.</a>
                    </div>

                    <div class="laser-col">
                        <h3 class="editable col-title" data-editable="text" data-prop="@data[corte_laser].col_2_title">{col_2_title}</h3>
                        <p class="editable" data-editable="text" data-prop="@data[corte_laser].col_2_desc">{col_2_desc}</p>
                        <ul class="laser-bullets">
                            <li>- ¿Este archivo está bien preparado?</li>
                            <li>- ¿Cómo cambia el precio si cambio el material o el grosor?</li>
                            <li>- ¿Cuánto cuesta fabricar esto ahora mismo?</li>
                            <li>- ¿Cómo paso esto a producción sin errores?</li>
                        </ul>
                    </div>

                    <div class="laser-side-actions">
                        <a href="#" class="side-btn red-btn">Pedir presupuesto online automático</a>
                        <a href="#" class="side-btn purple-btn">Quiero Justlasercut para mi empresa</a>
                    </div>
                </div>

                <hr class="laser-divider">

                <div class="laser-experience-section">
                    <div class="laser-banner-img">
                        <img class="editable" data-editable="image" data-prop="@data[corte_laser].experience_img" src={experience_img.src} alt={experience_img.alt}>
                    </div>

                    <hr class="laser-divider">

                    <h2 class="editable experience-title" data-editable="text" data-prop="@data[corte_laser].experience_title">{experience_title}</h2>
                    <div class="experience-intro">
                        <p class="editable" data-editable="text" data-prop="@data[corte_laser].experience_desc">{experience_desc}</p>
                    </div>

                    <div class="experience-features">
                        <div class="feature-item">
                            <i data-lucide="shopping-cart" class="check-icon"></i>
                            <p>Vender online sin correos ni presupuestos manuales.</p>
                        </div>
                        <div class="feature-item">
                            <i data-lucide="file-check" class="check-icon"></i>
                            <p>Revisar automáticamente los archivos de tus clientes.</p>
                        </div>
                        <div class="feature-item">
                            <i data-lucide="layers" class="check-icon"></i>
                            <p>Optimizar materiales y minimizar errores.</p>
                        </div>
                    </div>

                    <hr class="laser-divider">

                    <div class="experience-footer">
                        <div class="footer-left">
                            <h3 class="editable footer-highlight-title" data-editable="text" data-prop="@data[corte_laser].footer_highlight_title">{footer_highlight_title}</h3>
                            <p class="editable" data-editable="text" data-prop="@data[corte_laser].footer_highlight_desc">{footer_highlight_desc}</p>
                        </div>
                        <div class="footer-right-box">
                            <h4 class="box-title">¿Eres fabricante?</h4>
                            <p>JustLaserCut también está pensado para ti.</p>
                            <a href="#" class="btn-box-purple">Quiero Justlasercut para mi empresa</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>


---
import Layout from '../layouts/Layout.astro';

const {
  hero_title = "Maquinaria",
  hero_subtitle = "Nuestra tecnología a tu alcance.",
  machine_1_title = "Corte Láser",
  machine_1_desc = "Precisión extrema en diversos materiales.",
  machine_2_title = "Fresado CNC",
  machine_2_desc = "Para maderas, plásticos y metales blandos.",
  machine_3_title = "Impresión 3D",
  machine_3_desc = "Prototipado rápido y piezas finales funcionales."
} = Astro.props;
---

<Layout title="Maquinaria - Archicercle">
    <main>
        <section class="machine-hero">
            <div class="container">
                <h1 class="editable" data-editable="text" data-prop="hero_title">{hero_title}</h1>
                <p class="editable" data-editable="text" data-prop="hero_subtitle">{hero_subtitle}</p>
            </div>
        </section>

        <section class="machine-grid">
            <div class="container">
                <div class="machine-item">
                    <h3 class="editable" data-editable="text" data-prop="machine_1_title">{machine_1_title}</h3>
                    <p class="editable" data-editable="text" data-prop="machine_1_desc">{machine_1_desc}</p>
                </div>
                <div class="machine-item">
                    <h3 class="editable" data-editable="text" data-prop="machine_2_title">{machine_2_title}</h3>
                    <p class="editable" data-editable="text" data-prop="machine_2_desc">{machine_2_desc}</p>
                </div>
                <div class="machine-item">
                    <h3 class="editable" data-editable="text" data-prop="machine_3_title">{machine_3_title}</h3>
                    <p class="editable" data-editable="text" data-prop="machine_3_desc">{machine_3_desc}</p>
                </div>
            </div>
        </section>
    </main>
</Layout>

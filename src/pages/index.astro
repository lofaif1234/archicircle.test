---
import Layout from '../layouts/Layout.astro';
import pageData from '../data/pages/index.json';

const {
  hero_title = pageData.hero_title,
  hero_bg = pageData.hero_bg,
  hero_description = pageData.hero_description,
  feature_1_title = pageData.feature_1_title,
  feature_1_desc = pageData.feature_1_desc,
  feature_2_title = pageData.feature_2_title,
  feature_2_desc = pageData.feature_2_desc,
  feature_3_title = pageData.feature_3_title,
  feature_3_desc = pageData.feature_3_desc,
  feature_4_title = pageData.feature_4_title,
  feature_4_desc = pageData.feature_4_desc,
  feature_5_title = pageData.feature_5_title,
  feature_5_desc = pageData.feature_5_desc,
  why_us_title = pageData.why_us_title,
  why_us_subtitle = pageData.why_us_subtitle,
  workflow_title = pageData.workflow_title,
  workflow_subtitle = pageData.workflow_subtitle,
  idea_card_title = pageData.idea_card_title,
  idea_card_desc = pageData.idea_card_desc,
  services_section_title = pageData.services_section_title,
  service_1_name = pageData.service_1_name,
  service_1_desc = pageData.service_1_desc,
  service_2_name = pageData.service_2_name,
  service_2_desc = pageData.service_2_desc,
  service_3_name = pageData.service_3_name,
  service_3_desc = pageData.service_3_desc,
  service_4_name = pageData.service_4_name,
  service_4_desc = pageData.service_4_desc,
  studio_title = pageData.studio_title,
  studio_name = pageData.studio_name,
  studio_desc_1 = pageData.studio_desc_1,
  studio_desc_2 = pageData.studio_desc_2,
  studio_desc_3 = pageData.studio_desc_3,
  studio_img = pageData.studio_img,
  factory_title = pageData.factory_title,
  factory_name = pageData.factory_name,
  factory_desc = pageData.factory_desc,
  factory_img = pageData.factory_img
} = Astro.props;

---

<Layout title="Archicercle - Estudio Creativo">
    <main>
        <!-- Hero Section -->
        <section 
            class="hero editable" 
            data-editable="image" 
            data-prop="@data[index].hero_bg" 
            style={`background-image: url(${hero_bg.src});`}
        >
            <div class="hero-overlay"></div>
            <div class="container">
                <div class="hero-top">
                    <h1 class="editable" data-editable="text" data-prop="@data[index].hero_title" set:html={hero_title}></h1>
                    <p class="editable subtitle" data-editable="text" data-prop="@data[index].hero_description" set:html={hero_description}></p>
                    <div class="hero-ctas">
                        <a href="#" class="btn-main">Empieza tu proyecto hoy</a>
                        <a href="#" class="btn-main">Conoce nuestros servicios</a>
                    </div>
                </div>

                <div class="hero-divider"></div>

                <div class="features-layout">
                    <div class="feature-card">
                        <div class="feature-header">
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 10V6a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v4"/></svg>
                            <h3 class="editable" data-editable="text" data-prop="@data[index].feature_1_title">{feature_1_title}</h3>
                        </div>
                        <p class="editable" data-editable="text" data-prop="@data[index].feature_1_desc">{feature_1_desc}</p>
                    </div>

                    <div class="feature-card">
                        <div class="feature-header">
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19l7-7 3 3-7 7-3-3z"/><path d="M18 13l-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="M2 2l7.5 1.5"/><path d="M7 11l5-5"/></svg>
                            <h3 class="editable" data-editable="text" data-prop="@data[index].feature_2_title">{feature_2_title}</h3>
                        </div>
                        <p class="editable" data-editable="text" data-prop="@data[index].feature_2_desc">{feature_2_desc}</p>
                    </div>

                    <div class="feature-card">
                        <div class="feature-header">
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                            <h3 class="editable" data-editable="text" data-prop="@data[index].feature_3_title">{feature_3_title}</h3>
                        </div>
                        <p class="editable" data-editable="text" data-prop="@data[index].feature_3_desc">{feature_3_desc}</p>
                    </div>

                    <div class="feature-card">
                        <div class="feature-header">
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>
                            <h3 class="editable" data-editable="text" data-prop="@data[index].feature_4_title">{feature_4_title}</h3>
                        </div>
                        <p class="editable" data-editable="text" data-prop="@data[index].feature_4_desc">{feature_4_desc}</p>
                    </div>

                    <div class="feature-card">
                        <div class="feature-header">
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19c.3 0 .5-.1.7-.3.2-.2.3-.5.3-.7s-.1-.5-.3-.7c-.2-.2-.5-.3-.7-.3s-.5.1-.7.3c-.2.2-.3.5-.3.7s.1.5.3.7c.2.2.5.3.7.3z"/><path d="M12.5 19c.3 0 .5-.1.7-.3.2-.2.3-.5.3-.7s-.1-.5-.3-.7c-.2-.2-.5-.3-.7-.3s-.5.1-.7.3c-.2.2-.3.5-.3.7s.1.5.3.7c.2.2.5.3.7.3z"/><path d="M7.5 19c.3 0 .5-.1.7-.3.2-.2.3-.5.3-.7s-.1-.5-.3-.7c-.2-.2-.5-.3-.7-.3s-.5.1-.7.3c-.2.2-.3.5-.3.7s.1.5.3.7c.2.2.5.3.7.3z"/><path d="M20 12.5V11a8 8 0 0 0-16 0v1.5"/><path d="M3 12.5h18"/></svg>
                            <h3 class="editable" data-editable="text" data-prop="@data[index].feature_5_title">{feature_5_title}</h3>
                        </div>
                        <p class="editable" data-editable="text" data-prop="@data[index].feature_5_desc">{feature_5_desc}</p>
                    </div>

                    <div class="feature-action">
                        <a href="#" class="btn-project">Cuéntanos tu proyecto</a>
                    </div>
                </div>

                <div class="hero-divider"></div>

                <div class="why-us">
                    <h2 class="editable section-title" data-editable="text" data-prop="@data[index].why_us_title">{why_us_title}</h2>
                    <p class="editable section-subtitle" data-editable="text" data-prop="@data[index].why_us_subtitle">{why_us_subtitle}</p>
                    
                    <div class="why-grid">
                        <div class="why-item">
                            <svg class="why-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                            <span>Diseño funcional y estético</span>
                        </div>
                        <div class="why-item">
                            <svg class="why-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                            <span>Conocimiento técnico real</span>
                        </div>
                        <div class="why-item">
                            <svg class="why-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v3m18 8v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-3m18-8l-2 8H5l-2-8h18z"/><line x1="12" y1="12" x2="12" y2="12"/></svg>
                            <span>Producción ágil y de calidad</span>
                        </div>
                        <div class="why-item">
                            <svg class="why-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                            <span>Materiales y acabados</span>
                        </div>
                        <div class="why-item">
                            <svg class="why-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            <span>Tecnología propia y control total</span>
                        </div>
                    </div>
                </div>

                <div class="hero-divider"></div>

                <div class="workflow-section">
                    <div class="workflow-content">
                        <h2 class="editable section-title" data-editable="text" data-prop="@data[index].workflow_title">{workflow_title}</h2>
                        <p class="editable section-subtitle" data-editable="text" data-prop="@data[index].workflow_subtitle">{workflow_subtitle}</p>
                        
                        <div class="workflow-grid">
                            <div class="workflow-step">
                                <span class="step-num">1</span>
                                <div class="workflow-box">Nos cuentas tu idea</div>
                            </div>
                            <div class="workflow-step">
                                <span class="step-num">2</span>
                                <div class="workflow-box">La diseñamos contigo</div>
                            </div>
                            <div class="workflow-step">
                                <span class="step-num">3</span>
                                <div class="workflow-box">Prototipamos y verificamos</div>
                            </div>
                            <div class="workflow-step">
                                <span class="step-num">4</span>
                                <div class="workflow-box">Fabricamos y entregamos</div>
                            </div>
                        </div>
                    </div>

                    <div class="idea-card">
                        <h3 class="editable" data-editable="text" data-prop="@data[index].idea_card_title">{idea_card_title}</h3>
                        <p class="editable" data-editable="text" data-prop="@data[index].idea_card_desc">{idea_card_desc}</p>
                        <a href="#" class="btn-card">Quiero fabricar un producto</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Services -->
        <section class="services-section">
            <div class="container">
                <h2 class="editable services-main-title" data-editable="text" data-prop="@data[index].services_section_title">{services_section_title}</h2>
                <div class="services-grid">
                    <div class="service-card">
                        <div class="service-top">
                            <i data-lucide="pen-tool" class="service-icon"></i>
                        </div>
                        <div class="service-bottom">
                            <h3 class="editable" data-editable="text" data-prop="@data[index].service_1_name">{service_1_name}</h3>
                            <p class="editable" data-editable="text" data-prop="@data[index].service_1_desc">{service_1_desc}</p>
                            <a href="#" class="btn-info">+ INFO</a>
                        </div>
                    </div>

                    <div class="service-card">
                        <div class="service-top">
                            <i data-lucide="hammer" class="service-icon"></i>
                        </div>
                        <div class="service-bottom">
                            <h3 class="editable" data-editable="text" data-prop="@data[index].service_2_name">{service_2_name}</h3>
                            <p class="editable" data-editable="text" data-prop="@data[index].service_2_desc">{service_2_desc}</p>
                            <a href="#" class="btn-info">+ INFO</a>
                        </div>
                    </div>

                    <div class="service-card">
                        <div class="service-top">
                            <i data-lucide="award" class="service-icon"></i>
                        </div>
                        <div class="service-bottom">
                            <h3 class="editable" data-editable="text" data-prop="@data[index].service_3_name">{service_3_name}</h3>
                            <p class="editable" data-editable="text" data-prop="@data[index].service_3_desc">{service_3_desc}</p>
                            <a href="#" class="btn-info">+ INFO</a>
                        </div>
                    </div>

                    <div class="service-card">
                        <div class="service-top">
                            <i data-lucide="users" class="service-icon"></i>
                        </div>
                        <div class="service-bottom">
                            <h3 class="editable" data-editable="text" data-prop="@data[index].service_4_name">{service_4_name}</h3>
                            <p class="editable" data-editable="text" data-prop="@data[index].service_4_desc">{service_4_desc}</p>
                            <a href="/coworking" class="btn-info">+ INFO</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Studio -->
        <section class="studio-section">
            <div class="container">
                <div class="studio-layout">
                    <div class="studio-text">
                        <h2 class="editable studio-title" data-editable="text" data-prop="@data[index].studio_title">{studio_title}</h2>
                        <h4 class="editable studio-subtitle" data-editable="text" data-prop="@data[index].studio_name">{studio_name}</h4>
                        <p class="editable" data-editable="text" data-prop="@data[index].studio_desc_1">{studio_desc_1}</p>
                        <p class="editable" data-editable="text" data-prop="@data[index].studio_desc_2">{studio_desc_2}</p>
                        <p class="editable" data-editable="text" data-prop="@data[index].studio_desc_3">{studio_desc_3}</p>
                    </div>
                    <div class="studio-image">
                        <img class="editable" data-editable="image" data-prop="@data[index].studio_img" src={studio_img.src} alt={studio_img.alt}>
                        <a href="/servicios-de-diseno" class="image-btn">Servicios de diseño</a>
                    </div>
                </div>
            </div>
        </section>

        <!-- Factory -->
        <section class="factory-section">
            <div class="container">
                <div class="factory-layout">
                    <div class="factory-image">
                        <img class="editable" data-editable="image" data-prop="@data[index].factory_img" src={factory_img.src} alt={factory_img.alt}>
                    </div>
                    <div class="factory-text">
                        <h2 class="editable factory-title" data-editable="text" data-prop="@data[index].factory_title">{factory_title}</h2>
                        <h4 class="editable factory-subtitle" data-editable="text" data-prop="@data[index].factory_name">{factory_name}</h4>
                        <p class="editable" data-editable="text" data-prop="@data[index].factory_desc">{factory_desc}</p>
                        <div class="factory-ctas">
                            <a href="/maquinaria" class="btn-factory">Nuestras Máquinas</a>
                            <a href="/servicios-de-fabricacion" class="btn-factory">Servicios de Fabricación</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>


---
import Layout from '../layouts/Layout.astro';
import pageData from '../data/pages/declaracion.json';

const {
  hero_title = pageData.hero_title,
  hero_subtitle = pageData.hero_subtitle,
  declaracion_title = pageData.declaracion_title,
  declaracion_text = pageData.declaracion_text
} = Astro.props;
---

<Layout title="Declaración de Accesibilidad - Archicercle">
    <main>
        <section class="legal-hero">
            <div class="container">
                <h1 class="editable legal-main-title" data-editable="text" data-prop="@data[declaracion].hero_title">{hero_title}</h1>
                <p class="editable legal-subtitle" data-editable="text" data-prop="@data[declaracion].hero_subtitle">{hero_subtitle}</p>
            </div>
        </section>

        <section class="legal-body-section">
            <div class="container">
                <div class="legal-grid-layout">
                    <div class="legal-main-content">
                        <div class="legal-card">
                            <h2 class="editable" data-editable="text" data-prop="@data[declaracion].declaracion_title">{declaracion_title}</h2>
                            <p class="editable" data-editable="text" data-prop="@data[declaracion].declaracion_text">{declaracion_text}</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>


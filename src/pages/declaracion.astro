---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Declaración de Accesibilidad - Archicercle">
    <main>
        <!-- Legal Hero Section -->
        <section class="legal-hero">
            <div class="container">
                <h1  data-editable="text" class="editable legal-main-title" data-editable="text" data-prop="text_field">Accesibilidad</h1>
                <p  data-editable="text" class="editable legal-subtitle" data-editable="text" data-prop="text_field">Nuestro compromiso con un sitio web inclusivo para todos.</p>
            </div>
        </section>

        <section class="legal-body-section">
            <div class="container">
                <div class="legal-grid-layout">
                    <!-- Main Content -->
                    <div class="legal-main-content">
                        <div class="legal-card">
                            <h2  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Declaración de accesibilidad de Archicercle</h2>
                            <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Archicercle se compromete a hacer accesible su sitio web, de conformidad con el Real Decreto 1112/2018, de 7 de septiembre, sobre accesibilidad de los sitios web y aplicaciones para dispositivos móviles del sector público.</p>
                            
                            <div class="status-badge">
                                <i data-lucide="info"></i>
                                <span>Situación: Parcialmente conforme</span>
                            </div>
                        </div>

                        <div class="legal-card">
                            <h3  data-editable="text" class="editable" data-editable="text" data-prop="text_field">👉 Sitio Web Aplicable</h3>
                            <a href="https://archicercle.es" target="_blank" class="domain-link">https://archicercle.es</a>
                        </div>

                        <div class="legal-card">
                            <h3  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Contenido no accesible</h3>
                            <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Estamos trabajando activamente para resolver las siguientes limitaciones técnicas:</p>
                            
                            <div class="limitations-grid">
                                <div class="limitation-item">
                                    <span class="limitation-label">Contraste</span>
                                    <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Ajustando colores de texto y fondo para cumplir la norma UNE-EN 301549:2019.</p>
                                </div>
                                <div class="limitation-item">
                                    <span class="limitation-label">Imágenes</span>
                                    <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Añadiendo textos alternativos a imágenes decorativas y de contenido.</p>
                                </div>
                                <div class="limitation-item">
                                    <span class="limitation-label">Estructura</span>
                                    <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Optimizando la jerarquía de encabezados (H1, H2, H3) para lectores de pantalla.</p>
                                </div>
                                <div class="limitation-item">
                                    <span class="limitation-label">Formularios</span>
                                    <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Mejorando el etiquetado y asociación de campos en todos nuestros formularios.</p>
                                </div>
                                <div class="limitation-item">
                                    <span class="limitation-label">Navegación</span>
                                    <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Asegurando que todos los elementos sean operables mediante teclado.</p>
                                </div>
                            </div>
                        </div>

                        <div class="legal-card">
                            <h3  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Preparación y Revisión</h3>
                            <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Esta declaración fue preparada el <strong>21 de mayo de 2025</strong> mediante una autoevaluación interna exhaustiva.</p>
                            <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Última revisión: 21 de mayo de 2025.</p>
                        </div>
                    </div>

                    <!-- Sidebar / Action Area -->
                    <div class="legal-sidebar">
                        <div class="contact-card">
                            <i data-lucide="help-circle" class="contact-card-icon"></i>
                            <h4  data-editable="text" class="editable" data-editable="text" data-prop="text_field">¿Necesitas ayuda?</h4>
                            <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Si tienes dificultades para acceder a algún contenido, estamos aquí para ayudarte.</p>
                            <a href="mailto:hola@archicercle.es" class="btn-sidebar-contact">
                                <i data-lucide="mail"></i>
                                hola@archicercle.es
                            </a>
                        </div>

                        <div class="commitment-box">
                            <h4  data-editable="text" class="editable" data-editable="text" data-prop="text_field">Nuestro compromiso</h4>
                            <p  data-editable="text" class="editable" data-editable="text" data-prop="text_field">En Archicercle trabajamos para garantizar una experiencia digital inclusiva, adaptada a todas las capacidades y dispositivos.</p>
                            <ul class="commitment-list">
                                <li><i data-lucide="code"></i> Estructuras semánticas</li>
                                <li><i data-lucide="volume-2"></i> Pruebas con lectores</li>
                                <li><i data-lucide="monitor-smartphone"></i> Diseño Responsive</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

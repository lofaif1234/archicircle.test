---
import Layout from '../layouts/Layout.astro';

const {
  hero_title = "Accesibilidad",
  hero_subtitle = "Nuestro compromiso con un sitio web inclusivo para todos.",
  declaracion_title = "Declaración de accesibilidad de Archicercle",
  declaracion_text = "Archicercle se compromete a hacer accesible su sitio web, de conformidad con el Real Decreto 1112/2018, de 7 de septiembre, sobre accesibilidad de los sitios web y aplicaciones para dispositivos móviles del sector público."
} = Astro.props;
---

<Layout title="Declaración de Accesibilidad - Archicercle">
    <main>
        <section class="legal-hero">
            <div class="container">
                <h1 class="editable legal-main-title" data-editable="text" data-prop="hero_title">{hero_title}</h1>
                <p class="editable legal-subtitle" data-editable="text" data-prop="hero_subtitle">{hero_subtitle}</p>
            </div>
        </section>

        <section class="legal-body-section">
            <div class="container">
                <div class="legal-grid-layout">
                    <div class="legal-main-content">
                        <div class="legal-card">
                            <h2 class="editable" data-editable="text" data-prop="declaracion_title">{declaracion_title}</h2>
                            <p class="editable" data-editable="text" data-prop="declaracion_text">{declaracion_text}</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

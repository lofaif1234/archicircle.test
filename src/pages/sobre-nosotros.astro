---
import Layout from '../layouts/Layout.astro';
import pageData from '../data/pages/sobre-nosotros.json';

const {
  title = pageData.title,
  subtitle = pageData.subtitle,
  hero_bg = pageData.hero_bg,
  mission_title = pageData.mission_title,
  mission_text_1 = pageData.mission_text_1,
  mission_text_2 = pageData.mission_text_2,
  mission_text_3 = pageData.mission_text_3,
  team_title = pageData.team_title,
  team_member_1_name = pageData.team_member_1_name,
  team_member_1_role = pageData.team_member_1_role,
  team_member_1_img = pageData.team_member_1_img,
  team_member_2_name = pageData.team_member_2_name,
  team_member_2_role = pageData.team_member_2_role,
  team_member_2_img = pageData.team_member_2_img,
  team_member_3_name = pageData.team_member_3_name,
  team_member_3_role = pageData.team_member_3_role,
  team_member_3_img = pageData.team_member_3_img,
  philosophy_title = pageData.philosophy_title,
  philosophy_subtitle = pageData.philosophy_subtitle,
  contact_title = pageData.contact_title,
  contact_desc_1 = pageData.contact_desc_1,
  contact_desc_2 = pageData.contact_desc_2,
  contact_desc_3 = pageData.contact_desc_3,
  contact_desc_4 = pageData.contact_desc_4,
  contact_desc_5 = pageData.contact_desc_5
} = Astro.props;
---

<Layout title="Sobre nosotros - Archicercle">
    <main>
        <!-- About Hero Section -->
        <section class="about-hero">
            <div class="about-hero-overlay"></div>
            <img class="editable about-hero-bg" data-editable="image" data-prop="@data[sobre_nosotros].hero_bg" src={hero_bg.src} alt={hero_bg.alt}>
            <div class="container">
                <div class="about-hero-content">
                    <h1 class="editable about-title" data-editable="text" data-prop="@data[sobre_nosotros].title">{title}</h1>
                    <p class="editable about-subtitle" data-editable="text" data-prop="@data[sobre_nosotros].subtitle">{subtitle}</p>
                </div>
            </div>
        </section>

        <!-- Mission Section -->
        <section class="about-mission">
            <div class="container">
                <div class="mission-header">
                    <h2 class="editable mission-title" data-editable="text" data-prop="@data[sobre_nosotros].mission_title">{mission_title}</h2>
                </div>
                <div class="mission-content">
                    <p class="editable" data-editable="text" data-prop="@data[sobre_nosotros].mission_text_1">{mission_text_1}</p>
                    <p class="editable" data-editable="text" data-prop="@data[sobre_nosotros].mission_text_2">{mission_text_2}</p>
                    <p class="editable" data-editable="text" data-prop="@data[sobre_nosotros].mission_text_3">{mission_text_3}</p>
                </div>

                <div class="team-section">
                    <h2 class="editable team-main-title" data-editable="text" data-prop="@data[sobre_nosotros].team_title">{team_title}</h2>
                    <div class="team-grid">
                        <div class="team-card">
                            <div class="team-img">
                                <img class="editable" data-editable="image" data-prop="@data[sobre_nosotros].team_member_1_img" src={team_member_1_img.src} alt={team_member_1_img.alt}>
                            </div>
                            <div class="team-info">
                                <h4 class="editable member-name" data-editable="text" data-prop="@data[sobre_nosotros].team_member_1_name">{team_member_1_name}</h4>
                                <p class="editable member-role" data-editable="text" data-prop="@data[sobre_nosotros].team_member_1_role">{team_member_1_role}</p>
                            </div>
                        </div>

                        <div class="team-card">
                            <div class="team-img">
                                <img class="editable" data-editable="image" data-prop="@data[sobre_nosotros].team_member_2_img" src={team_member_2_img.src} alt={team_member_2_img.alt}>
                            </div>
                            <div class="team-info">
                                <h4 class="editable member-name" data-editable="text" data-prop="@data[sobre_nosotros].team_member_2_name">{team_member_2_name}</h4>
                                <p class="editable member-role" data-editable="text" data-prop="@data[sobre_nosotros].team_member_2_role">{team_member_2_role}</p>
                            </div>
                        </div>

                        <div class="team-card">
                            <div class="team-img">
                                <img class="editable" data-editable="image" data-prop="@data[sobre_nosotros].team_member_3_img" src={team_member_3_img.src} alt={team_member_3_img.alt}>
                            </div>
                            <div class="team-info">
                                <h4 class="editable member-name" data-editable="text" data-prop="@data[sobre_nosotros].team_member_3_name">{team_member_3_name}</h4>
                                <p class="editable member-role" data-editable="text" data-prop="@data[sobre_nosotros].team_member_3_role">{team_member_3_role}</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        
        <!-- Philosophy Section -->
        <section class="about-philosophy">
            <div class="container">
                <h2 class="editable philosophy-title" data-editable="text" data-prop="@data[sobre_nosotros].philosophy_title">{philosophy_title}</h2>
                <p class="editable philosophy-subtitle" data-editable="text" data-prop="@data[sobre_nosotros].philosophy_subtitle">{philosophy_subtitle}</p>
                
                <div class="philosophy-accordion">
                    <div class="philosophy-container">
                        <div class="philosophy-item">
                            <button class="philosophy-btn">
                                <span>¿De dónde venimos?</span>
                                <span class="plus">+</span>
                            </button>
                        </div>
                        <div class="philosophy-item">
                            <button class="philosophy-btn">
                                <span>¿A dónde vamos?</span>
                                <span class="plus">+</span>
                            </button>
                        </div>
                        <div class="philosophy-item">
                            <button class="philosophy-btn">
                                <span>¿Quiénes son nuestros clientes?</span>
                                <span class="plus">+</span>
                            </button>
                        </div>
                        <div class="philosophy-item">
                            <button class="philosophy-btn">
                                <span>¿Cómo lo hacemos?</span>
                                <span class="plus">+</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Red Contact Section -->
        <section class="contact-section-red">
            <div class="container">
                <div class="contact-layout">
                    <div class="contact-info">
                        <h2 class="editable contact-title" data-editable="text" data-prop="@data[sobre_nosotros].contact_title">{contact_title}</h2>
                        <div class="contact-description">
                            <p class="editable" data-editable="text" data-prop="@data[sobre_nosotros].contact_desc_1">{contact_desc_1}</p>
                            <p class="editable" data-editable="text" data-prop="@data[sobre_nosotros].contact_desc_2">{contact_desc_2}</p>
                            <p class="editable" data-editable="text" data-prop="@data[sobre_nosotros].contact_desc_3">{contact_desc_3}</p>
                            <p class="editable" data-editable="text" data-prop="@data[sobre_nosotros].contact_desc_4">{contact_desc_4}</p>
                            <p class="editable" data-editable="text" data-prop="@data[sobre_nosotros].contact_desc_5"><strong>{contact_desc_5}</strong></p>
                        </div>
                        
                        <ul class="contact-meta">
                            <li>
                                <i data-lucide="map-pin"></i>
                                <span>Calle Utiel nº 6, CP 46021 (Cerca de la parada de metro de Benimaclet)</span>
                            </li>
                            <li>
                                <i data-lucide="mail"></i>
                                <span>archicercle@archicercle.com</span>
                            </li>
                            <li>
                                <i data-lucide="phone"></i>
                                <span>649 999 853</span>
                            </li>
                        </ul>
                    </div>

                    <div class="contact-form-wrapper">
                        <form class="contact-form">
                            <div class="form-group">
                                <label for="consulta">Consulta</label>
                                <select id="consulta" name="consulta">
                                    <option value="diseno">Servicios de Diseño</option>
                                    <option value="fabricacion">Servicios de Fabricación</option>
                                    <option value="coworking">Coworking</option>
                                    <option value="otros">Otros</option>
                                </select>
                            </div>
                            
                            <div class="form-group">
                                <label for="nombre">Nombre</label>
                                <input type="text" id="nombre" name="nombre" placeholder="Nombre">
                            </div>

                            <div class="form-group">
                                <label for="email">Correo electrónico</label>
                                <input type="email" id="email" name="email" placeholder="Correo electrónico">
                            </div>

                            <div class="form-group">
                                <label for="telefono">Teléfono</label>
                                <input type="tel" id="telefono" name="telefono" placeholder="Teléfono">
                            </div>

                            <div class="form-group">
                                <label for="mensaje">Mensaje</label>
                                <textarea id="mensaje" name="mensaje" placeholder="Mensaje" rows="5"></textarea>
                            </div>

                            <div class="form-privacy">
                                <input type="checkbox" id="privacy" name="privacy" required>
                                <label for="privacy">He leído y acepto el aviso legal y la política de privacidad.</label>
                            </div>

                            <button type="submit" class="btn-submit">Enviar</button>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>

